# TallyDekho Mobile App — Environment Variables
# React Native uses src/services/api/config.js for API URLs
# No .env file needed — update config.js directly

# For local testing (already set in config.js):
# DEV_API_URL=http://YOUR_LOCAL_IP:3001/app
# DEV_WS_URL=ws://YOUR_LOCAL_IP:3001

# For production release (update in config.js before building):
# PROD_API_URL=https://api.your-domain.com/app
# PROD_WS_URL=wss://api.your-domain.com
